# BBT Reporter - Cloud Gateway
# Deny access to sensitive files
<IfModule mod_rewrite.c>
    # Redirect ke index jika bukan file yang valid
    RewriteEngine On
    
    # Blokir akses langsung ke config.php
    RewriteRule ^config\.php$ - [F]
    
    # Blokir akses langsung ke folder data
    RewriteRule ^data/ - [F]
</IfModule>

# Blokir akses ke data folder
<IfModule mod_authz_core.c>
    <Directory "data">
        Require all denied
    </Directory>
</IfModule>

# Blokir akses ke config
<Files "config.php">
    Require all denied
</Files>

# Enable CORS (jika tidak bisa via PHP header)
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, POST, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, X-API-Key"
</IfModule>
